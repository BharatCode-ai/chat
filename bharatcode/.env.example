PORT=3080
NODE_ENV=development

DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080
CONFIG_PATH=bharatcode/librechat.yaml

MONGO_URI=mongodb://mongodb:27017/BharatCodeChat
